{
  "name": "@repull/ai-sdk",
  "version": "0.2.0",
  "description": "Vercel AI SDK tool bindings + embedded <RepullAgent /> chat widget for the Repull API.",
  "license": "MIT",
  "author": "Repull",
  "homepage": "https://repull.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ivannikolovbg/repull-ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ivannikolovbg/repull-ai-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./headless": {
      "types": "./dist/headless/index.d.ts",
      "import": "./dist/headless/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:example": "tsc -p tsconfig.example.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "repull",
    "ai-sdk",
    "vercel",
    "ai",
    "tools",
    "tool-calling",
    "openai",
    "anthropic",
    "kimi",
    "agent",
    "chat-widget",
    "vacation-rental",
    "airbnb",
    "booking",
    "channel-manager",
    "pms"
  ],
  "peerDependencies": {
    "ai": ">=4.0.0 <7.0.0",
    "react": ">=18.0.0 <20.0.0",
    "zod": "^3.23.8 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.55",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^6.0.171",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18"
  }
}
